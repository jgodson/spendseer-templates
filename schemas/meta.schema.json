{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spendseer.dev/schemas/community-meta.schema.json",
  "title": "Community Template Metadata",
  "type": "object",
  "required": ["slug", "version", "name", "author", "summary"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+(?:\\.\\d+){0,2}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "properties": {
        "institution": { "type": "string" },
        "csv_export_path": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
